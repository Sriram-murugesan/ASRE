# --- Mode switch ---
# mock: deterministic, zero network calls, no key needed. Default.
# llm:  real Groq calls, requires GROQ_API_KEY below.
ASRE_MODE=mock

# --- Retrieval backend ---
# tfidf: default, no model download, fully offline.
# faiss: production path, requires `pip install .[production-retrieval]`.
ASRE_RETRIEVAL=tfidf

# --- Groq (only required when ASRE_MODE=llm) ---
GROQ_API_KEY=

# --- Supabase (optional, only required if logging is enabled) ---
SUPABASE_URL=
SUPABASE_KEY=
